#!/usr/bin/env bash
set -euo pipefail

TOOL_NAME="claude-code"
TOOL_DESC="AI coding assistant (Anthropic)"

if [[ $# -eq 0 ]]; then
    echo "${TOOL_NAME} — ${TOOL_DESC}"
    echo "Usage: $0 <target-dir>"
    exit 0
fi

target="$1"
[[ -d "$target" ]] || { echo "Error: target directory does not exist: $target" >&2; exit 1; }

CLAUDE_GCS="https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"

if [[ "${2:-}" == "version-check" ]]; then
    installed_ver="none"
    latest_ver="unknown"
    if [[ -x "${target}/claude" ]]; then
        installed_ver=$("${target}/claude" --version 2>/dev/null | head -1) || installed_ver="none"
    fi
    latest_ver=$(curl -fsSL "${CLAUDE_GCS}/latest" 2>/dev/null) || latest_ver="unknown"
    echo "installed=${installed_ver}"
    echo "latest=${latest_ver}"
    exit 0
fi

if [[ "$(uname -m)" != "x86_64" ]]; then
    echo "ERROR: claude-code requires x86_64 — $(uname -m) is not supported" >&2
    exit 1
fi

version=$(curl -fsSL "${CLAUDE_GCS}/latest")
echo "Installing claude-code ${version} to ${target}"
curl -fsSL -o "${target}/claude" "${CLAUDE_GCS}/${version}/linux-x64/claude"
chmod +x "${target}/claude"

# Verify SHA256 checksum from manifest
manifest=$(curl -fsSL "${CLAUDE_GCS}/${version}/manifest.json" 2>/dev/null) || manifest=""
expected_sha=$(printf '%s' "$manifest" \
    | tr -d '\n' \
    | grep -oE '"linux-x64"\s*:\s*\{[^}]*\}' \
    | grep -oE '"checksum"\s*:\s*"(sha256:)?[a-f0-9]{64}"' \
    | grep -oE '[a-f0-9]{64}') || expected_sha=""

if [[ -n "$expected_sha" ]]; then
    actual_sha=$(sha256sum "${target}/claude" | awk '{print $1}')
    if [[ "$actual_sha" != "$expected_sha" ]]; then
        rm -f "${target}/claude"
        echo "ERROR: SHA256 mismatch for claude binary — aborting" >&2
        echo "  expected: ${expected_sha}" >&2
        echo "  got:      ${actual_sha}" >&2
        exit 1
    fi
    echo "  SHA256 verified"
else
    echo "WARN: claude-code: manifest not available for ${version} — cannot verify download" >&2
    if [[ -t 0 ]]; then
        read -r -p "Continue without verification? [y/N] " reply
        [[ "${reply:-N}" =~ ^[Yy]$ ]] || { rm -f "${target}/claude"; exit 1; }
    else
        echo "ERROR: non-interactive — aborting unverified install" >&2
        rm -f "${target}/claude"
        exit 1
    fi
fi

# Generate uninstaller (Candidate B: lib/uninstallers/)
uninstaller="${target}/../lib/uninstallers/${TOOL_NAME}"
mkdir -p "$(dirname "$uninstaller")"
cat > "$uninstaller" <<UNINSTALL
#!/usr/bin/env bash
# Uninstaller for ${TOOL_NAME} — generated by tools/${TOOL_NAME}
rm -f "${target}/claude"
rm -f "\$(dirname "\$0")/${TOOL_NAME}"
UNINSTALL
chmod +x "$uninstaller"

echo "  ${TOOL_NAME} installed successfully."
