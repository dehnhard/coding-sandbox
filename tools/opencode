#!/usr/bin/env bash
set -euo pipefail

TOOL_NAME="opencode"
TOOL_DESC="AI coding assistant (anomalyco/opencode)"

if [[ $# -eq 0 ]]; then
    echo "${TOOL_NAME} — ${TOOL_DESC}"
    echo "Usage: $0 <target-dir>"
    exit 0
fi

target="$1"
[[ -d "$target" ]] || { echo "Error: target directory does not exist: $target" >&2; exit 1; }

if [[ "${2:-}" == "version-check" ]]; then
    installed_ver="none"
    latest_ver="unknown"
    if [[ -x "${target}/opencode" ]]; then
        installed_ver=$("${target}/opencode" version 2>/dev/null | head -1) || installed_ver="none"
    fi
    release_info=$(curl -fsSL "https://api.github.com/repos/anomalyco/opencode/releases/latest" 2>/dev/null) || release_info=""
    latest_ver=$(echo "${release_info}" | grep -o '"tag_name": *"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"v') || latest_ver="unknown"
    echo "installed=${installed_ver}"
    echo "latest=${latest_ver:-unknown}"
    exit 0
fi

if [[ "$(uname -m)" != "x86_64" ]]; then
    echo "ERROR: opencode requires x86_64 — $(uname -m) is not supported" >&2
    exit 1
fi

# GitHub API returns tag_name like "v1.2.3" — strip the leading "v" for display
release_info=$(curl -fsSL "https://api.github.com/repos/anomalyco/opencode/releases/latest")
version=$(echo "${release_info}" | grep -o '"tag_name": *"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"' || true)
[[ -n "$version" ]] || { echo "ERROR: Could not determine opencode version from GitHub API" >&2; exit 1; }
echo "Installing opencode ${version} to ${target}"

# Download tarball to tmpdir for verification before extraction
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT INT TERM

curl -fsSL "https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-x64.tar.gz" \
    -o "${tmpdir}/opencode-linux-x64.tar.gz"

# Fetch AUR PKGBUILD for SHA256 cross-reference
verified=false
pkgbuild=$(curl -fsSL "https://aur.archlinux.org/cgit/aur.git/plain/PKGBUILD?h=opencode-bin" 2>/dev/null) || pkgbuild=""

if [[ -n "$pkgbuild" ]]; then
    aur_ver=$(echo "$pkgbuild" | grep -m1 '^pkgver=' | cut -d= -f2 | tr -d "'" | tr -d '"') || aur_ver=""
    aur_sha=$(echo "$pkgbuild" | grep "^sha256sums_x86_64=" | grep -oE '[a-f0-9]{64}') || aur_sha=""

    # Strip leading "v" from GitHub version for comparison
    release_ver="${version#v}"

    if [[ -n "$aur_ver" && "$aur_ver" == "$release_ver" && -n "$aur_sha" && "$aur_sha" != "SKIP" ]]; then
        actual_sha=$(sha256sum "${tmpdir}/opencode-linux-x64.tar.gz" | cut -d' ' -f1)
        if [[ "$actual_sha" == "$aur_sha" ]]; then
            echo "SHA256 verified via AUR PKGBUILD (${actual_sha})"
            verified=true
        else
            echo "SECURITY: SHA256 mismatch! Expected ${aur_sha}, got ${actual_sha}" >&2
            rm -rf "$tmpdir"
            exit 1
        fi
    else
        echo "AUR version (${aur_ver:-unknown}) does not match release (${release_ver}), cannot verify SHA256" >&2
    fi
else
    echo "AUR PKGBUILD unavailable, cannot verify SHA256" >&2
fi

if [[ "$verified" != "true" ]]; then
    if [[ -t 0 ]]; then
        printf "Continue without SHA256 verification? [y/N] " >&2
        read -r answer
        if [[ "${answer,,}" != "y" ]]; then
            echo "Aborted by user." >&2
            rm -rf "$tmpdir"
            exit 1
        fi
    else
        echo "ERROR: Non-interactive mode and SHA256 verification unavailable — aborting" >&2
        rm -rf "$tmpdir"
        exit 1
    fi
fi

tar xz -C "${target}" opencode < "${tmpdir}/opencode-linux-x64.tar.gz"
chmod +x "${target}/opencode"
rm -rf "$tmpdir"

# Generate uninstaller
uninstaller="${target}/../lib/uninstallers/${TOOL_NAME}"
mkdir -p "$(dirname "$uninstaller")"
cat > "$uninstaller" <<UNINSTALL
#!/usr/bin/env bash
# Uninstaller for ${TOOL_NAME} — generated by tools/${TOOL_NAME}
rm -f "${target}/opencode"
rm -f "\$(dirname "\$0")/${TOOL_NAME}"
UNINSTALL
chmod +x "$uninstaller"
