#!/usr/bin/env bash
set -euo pipefail

TOOL_NAME="crush"
TOOL_DESC="Glamorous agentic coding (charmbracelet/crush)"

if [[ $# -eq 0 ]]; then
    echo "${TOOL_NAME} — ${TOOL_DESC}"
    echo "Usage: $0 <target-dir>"
    exit 0
fi

target="$1"
[[ -d "$target" ]] || { echo "Error: target directory does not exist: $target" >&2; exit 1; }

if [[ "${2:-}" == "version-check" ]]; then
    installed_ver="none"
    latest_ver="unknown"
    if [[ -x "${target}/crush" ]]; then
        installed_ver=$("${target}/crush" --version 2>/dev/null | awk '{print $NF}') || installed_ver="none"
    fi
    release_info=$(curl -fsSL "https://api.github.com/repos/charmbracelet/crush/releases/latest" 2>/dev/null) || release_info=""
    latest_ver=$(echo "${release_info}" | grep -o '"tag_name": *"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"v') || latest_ver="unknown"
    echo "installed=${installed_ver}"
    echo "latest=${latest_ver:-unknown}"
    exit 0
fi

if [[ "$(uname -m)" != "x86_64" ]]; then
    echo "ERROR: crush requires x86_64 — $(uname -m) is not supported" >&2
    exit 1
fi

release_info=$(curl -fsSL "https://api.github.com/repos/charmbracelet/crush/releases/latest")
version=$(echo "${release_info}" | grep -o '"tag_name": *"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"' || true)
[[ -n "$version" ]] || { echo "ERROR: Could not determine crush version from GitHub API" >&2; exit 1; }
echo "Installing crush ${version} to ${target}"

# --- Download and verify ---
tmpdir=$(mktemp -d)
trap 'rm -rf "${tmpdir}"' EXIT INT TERM

tarball="crush_${version#v}_Linux_x86_64.tar.gz"
base_url="https://github.com/charmbracelet/crush/releases/download/${version}"

curl -fsSL -o "${tmpdir}/${tarball}" "${base_url}/${tarball}"

# --- SHA256 verification via checksums.txt ---
# Note: Sigstore/cosign was evaluated but removed — Debian Trixie's cosign
# (GitVersion: devel) cannot verify current bundle formats. SHA256 over HTTPS
# from GitHub provides sufficient integrity assurance. See spec section 2.
verified=false
if curl -fsSL -o "${tmpdir}/checksums.txt" "${base_url}/checksums.txt" 2>/dev/null; then
    expected_sha=$(awk -v f="${tarball}" '$2 == f {print $1}' "${tmpdir}/checksums.txt")
    if [[ -n "${expected_sha}" ]]; then
        actual_sha=$(sha256sum "${tmpdir}/${tarball}" | awk '{print $1}')
        if [[ "${expected_sha}" != "${actual_sha}" ]]; then
            echo "ERROR: SHA256 mismatch for ${tarball}" >&2
            echo "  expected: ${expected_sha}" >&2
            echo "  actual:   ${actual_sha}" >&2
            exit 1
        fi
        echo "SHA256 checksum verified (via checksums.txt)"
        verified=true
    fi
fi

if [[ "${verified}" != "true" ]]; then
    echo "WARNING: could not verify SHA256 checksum" >&2
    if [[ -t 0 ]]; then
        printf 'Continue without verification? [y/N] ' >&2
        read -r answer
        [[ "${answer}" =~ ^[Yy]$ ]] || { echo "Aborted by user" >&2; exit 1; }
    else
        echo "ERROR: non-interactive mode — cannot proceed without verification" >&2
        exit 1
    fi
fi

# Extract verified tarball
tar xz --strip-components=1 -C "${target}" --wildcards '*/crush' < "${tmpdir}/${tarball}"
chmod +x "${target}/crush"

# Generate uninstaller
uninstaller="${target}/../lib/uninstallers/${TOOL_NAME}"
mkdir -p "$(dirname "$uninstaller")"
cat > "$uninstaller" <<UNINSTALL
#!/usr/bin/env bash
# Uninstaller for ${TOOL_NAME} — generated by tools/${TOOL_NAME}
rm -f "${target}/crush"
rm -f "\$(dirname "\$0")/${TOOL_NAME}"
UNINSTALL
chmod +x "$uninstaller"
